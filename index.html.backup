<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>LyDian Voice</title>
    <link rel="icon" type="image/png" href="/lydian-favicon.png">
    <link rel="apple-touch-icon" href="/icon-192.png">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
            background: #000000;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
            touch-action: manipulation;
        }

        /* Premium animated gradient background */
        .gradient-bg {
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 30% 20%, rgba(102, 126, 234, 0.15) 0%, transparent 50%),
                        radial-gradient(circle at 70% 80%, rgba(118, 75, 162, 0.15) 0%, transparent 50%),
                        radial-gradient(circle at 50% 50%, rgba(0, 224, 174, 0.08) 0%, transparent 50%);
            animation: gradientShift 15s ease-in-out infinite;
        }

        @keyframes gradientShift {
            0%, 100% {
                transform: scale(1) rotate(0deg);
                opacity: 1;
            }
            50% {
                transform: scale(1.1) rotate(5deg);
                opacity: 0.8;
            }
        }

        /* Floating particles */
        .particles {
            position: absolute;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 0;
        }

        .particle {
            position: absolute;
            width: 3px;
            height: 3px;
            background: rgba(255, 255, 255, 0.4);
            border-radius: 50%;
            pointer-events: none;
            animation: floatParticle 25s infinite ease-in-out;
        }

        @keyframes floatParticle {
            0%, 100% {
                transform: translate(0, 0) scale(1);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            50% {
                transform: translate(var(--tx), var(--ty)) scale(1.5);
            }
        }

        /* Main container */
        .voice-container {
            position: relative;
            z-index: 1;
            text-align: center;
            padding: 20px;
            width: 100%;
            max-width: 600px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }

        /* Logo - Only LyDian */
        .logo {
            font-size: clamp(3rem, 8vw, 5rem);
            font-weight: 900;
            background: linear-gradient(135deg, #667eea 0%, #00E0AE 50%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 80px;
            letter-spacing: 0.05em;
            animation: logoFloat 4s ease-in-out infinite;
            text-shadow: 0 0 40px rgba(102, 126, 234, 0.3);
        }

        @keyframes logoFloat {
            0%, 100% {
                transform: translateY(0) scale(1);
            }
            50% {
                transform: translateY(-10px) scale(1.02);
            }
        }

        /* Voice button container with glow rings */
        .voice-button-container {
            position: relative;
            width: 200px;
            height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 60px;
        }

        /* Glow rings */
        .glow-ring {
            position: absolute;
            width: 200px;
            height: 200px;
            border-radius: 50%;
            border: 2px solid rgba(102, 126, 234, 0.3);
            opacity: 0;
            pointer-events: none;
        }

        .glow-ring.active {
            animation: expandRing 2s ease-out infinite;
        }

        .glow-ring:nth-child(2) {
            animation-delay: 0.5s;
        }

        .glow-ring:nth-child(3) {
            animation-delay: 1s;
        }

        @keyframes expandRing {
            0% {
                width: 200px;
                height: 200px;
                opacity: 1;
                border-color: rgba(102, 126, 234, 0.8);
            }
            100% {
                width: 350px;
                height: 350px;
                opacity: 0;
                border-color: rgba(102, 126, 234, 0);
            }
        }

        /* Voice button */
        .voice-button {
            position: relative;
            width: 180px;
            height: 180px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            cursor: pointer;
            box-shadow: 0 20px 60px rgba(102, 126, 234, 0.4),
                        0 0 100px rgba(102, 126, 234, 0.2);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 10;
            display: flex;
            align-items: center;
            justify-content: center;
            outline: none;
            -webkit-tap-highlight-color: transparent;
        }

        .voice-button:active {
            transform: scale(0.95);
        }

        .voice-button.listening {
            animation: breathe 2s ease-in-out infinite;
            box-shadow: 0 25px 80px rgba(102, 126, 234, 1),
                        0 0 150px rgba(102, 126, 234, 0.6);
        }

        .voice-button.speaking {
            animation: speakPulse 0.8s ease-in-out infinite;
            background: linear-gradient(135deg, #00E0AE 0%, #667eea 100%);
            box-shadow: 0 25px 80px rgba(0, 224, 174, 0.8),
                        0 0 150px rgba(0, 224, 174, 0.5);
        }

        .voice-button.processing {
            animation: processingPulse 1.5s ease-in-out infinite;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            box-shadow: 0 25px 80px rgba(118, 75, 162, 0.9),
                        0 0 150px rgba(118, 75, 162, 0.6);
        }

        @keyframes breathe {
            0%, 100% {
                transform: scale(1);
                box-shadow: 0 20px 60px rgba(102, 126, 234, 0.6),
                            0 0 100px rgba(102, 126, 234, 0.3);
            }
            50% {
                transform: scale(1.08);
                box-shadow: 0 25px 80px rgba(102, 126, 234, 1),
                            0 0 150px rgba(102, 126, 234, 0.7);
            }
        }

        @keyframes speakPulse {
            0%, 100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.05);
            }
        }

        @keyframes processingPulse {
            0%, 100% {
                transform: scale(1) rotate(0deg);
                opacity: 1;
            }
            50% {
                transform: scale(1.03) rotate(2deg);
                opacity: 0.9;
            }
        }

        /* Microphone icon */
        .mic-icon {
            width: 60px;
            height: 60px;
            color: #FFFFFF;
            filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.3));
        }

        /* Audio visualizer */
        .audio-visualizer {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            height: 80px;
            margin-bottom: 40px;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .audio-visualizer.active {
            opacity: 1;
        }

        .visualizer-bar {
            width: 4px;
            height: 20px;
            background: linear-gradient(to top, #667eea, #00E0AE);
            border-radius: 2px;
            transition: height 0.1s ease;
        }

        /* Transcription display (hidden but used for processing) */
        .transcript {
            position: absolute;
            left: -9999px;
            opacity: 0;
        }

        /* Error message */
        .error-message {
            position: fixed;
            bottom: 40px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(255, 59, 59, 0.9);
            color: white;
            padding: 16px 24px;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 500;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            z-index: 1000;
            max-width: 90%;
            text-align: center;
            box-shadow: 0 10px 40px rgba(255, 59, 59, 0.4);
        }

        .error-message.show {
            opacity: 1;
        }

        /* Permission prompt */
        .permission-prompt {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(20px);
            padding: 32px;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            text-align: center;
            z-index: 1000;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            max-width: 90%;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        .permission-prompt.show {
            opacity: 1;
            pointer-events: auto;
        }

        .permission-prompt h3 {
            color: #FFFFFF;
            font-size: 24px;
            margin-bottom: 12px;
        }

        .permission-prompt p {
            color: rgba(255, 255, 255, 0.7);
            font-size: 16px;
            line-height: 1.5;
        }

        /* Premium Loading Spinner with Processing Text */
        .spinner {
            display: none;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            opacity: 0;
            transition: opacity 0.3s ease;
            margin: 20px auto;
        }

        .spinner.show {
            display: flex;
            opacity: 1;
        }

        .spinner-ring {
            width: 50px;
            height: 50px;
            position: relative;
        }

        .spinner-ring::before,
        .spinner-ring::after {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 50%;
            border: 3px solid transparent;
        }

        .spinner-ring::before {
            border-top-color: #00E0AE;
            border-right-color: #00E0AE;
            animation: spinPremium 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
        }

        .spinner-ring::after {
            border-top-color: rgba(0, 224, 174, 0.3);
            border-right-color: rgba(0, 224, 174, 0.3);
            animation: spinPremium 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
            animation-delay: 0.3s;
        }

        .processing-text {
            color: rgba(255, 255, 255, 0.8);
            font-size: 0.9rem;
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        .processing-dots::after {
            content: '';
            animation: processingDots 1.5s steps(4) infinite;
        }

        @keyframes spinPremium {
            0% {
                transform: rotate(0deg);
            }
            100% {
                transform: rotate(360deg);
            }
        }

        @keyframes processingDots {
            0%, 20% { content: ''; }
            40% { content: '.'; }
            60% { content: '..'; }
            80%, 100% { content: '...'; }
        }

        /* Chat History Panel */
        .chat-history {
            position: fixed;
            bottom: 20px;
            left: 20px;
            width: 350px;
            max-height: 400px;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(20px);
            border-radius: 16px;
            border: 1px solid rgba(102, 126, 234, 0.3);
            padding: 16px;
            overflow-y: auto;
            opacity: 0;
            transform: translateY(20px);
            pointer-events: none;
            transition: all 0.3s ease;
            z-index: 100;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        }

        .chat-history.show {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }

        .chat-history-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .chat-history-title {
            color: #fff;
            font-size: 14px;
            font-weight: 600;
        }

        .chat-clear-btn {
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.5);
            cursor: pointer;
            font-size: 12px;
            padding: 4px 8px;
            border-radius: 4px;
            transition: all 0.2s ease;
        }

        .chat-clear-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
        }

        .chat-message {
            margin-bottom: 12px;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-10px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .chat-message-user {
            color: #667eea;
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .chat-message-text {
            color: rgba(255, 255, 255, 0.9);
            font-size: 13px;
            line-height: 1.4;
            background: rgba(255, 255, 255, 0.05);
            padding: 8px 10px;
            border-radius: 8px;
        }

        .chat-message.ai .chat-message-user {
            color: #00E0AE;
        }

        /* Voice Settings Panel */
        .settings-panel {
            position: fixed;
            top: 20px;
            right: 20px;
            width: 280px;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(20px);
            border-radius: 16px;
            border: 1px solid rgba(102, 126, 234, 0.3);
            padding: 16px;
            opacity: 0;
            transform: translateY(-20px);
            pointer-events: none;
            transition: all 0.3s ease;
            z-index: 100;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
        }

        .settings-panel.show {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }

        .settings-title {
            color: #fff;
            font-size: 14px;
            font-weight: 600;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .settings-group {
            margin-bottom: 16px;
        }

        .settings-label {
            color: rgba(255, 255, 255, 0.7);
            font-size: 12px;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
        }

        .settings-value {
            color: #00E0AE;
            font-weight: 600;
        }

        .settings-slider {
            width: 100%;
            height: 4px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 2px;
            outline: none;
            -webkit-appearance: none;
        }

        .settings-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 16px;
            height: 16px;
            background: linear-gradient(135deg, #667eea, #00E0AE);
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(102, 126, 234, 0.4);
        }

        .settings-slider::-moz-range-thumb {
            width: 16px;
            height: 16px;
            background: linear-gradient(135deg, #667eea, #00E0AE);
            border-radius: 50%;
            cursor: pointer;
            border: none;
            box-shadow: 0 2px 8px rgba(102, 126, 234, 0.4);
        }

        /* Toggle Buttons */
        .toggle-buttons {
            position: fixed;
            bottom: 20px;
            right: 20px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            z-index: 99;
        }

        .toggle-btn {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(102, 126, 234, 0.3);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            color: rgba(255, 255, 255, 0.7);
            transition: all 0.2s ease;
            font-size: 20px;
        }

        .toggle-btn:hover {
            background: rgba(102, 126, 234, 0.2);
            border-color: rgba(102, 126, 234, 0.6);
            color: #fff;
            transform: scale(1.05);
        }

        .toggle-btn.active {
            background: linear-gradient(135deg, #667eea, #00E0AE);
            border-color: transparent;
            color: #fff;
        }

        /* Mobile optimizations */
        @media (max-width: 768px) {
            .chat-history {
                width: calc(100% - 40px);
                max-height: 300px;
                left: 20px;
                right: 20px;
            }

            .settings-panel {
                width: calc(100% - 40px);
                left: 20px;
                right: 20px;
                top: 10px;
            }

            .toggle-buttons {
                bottom: 10px;
                right: 10px;
            }

            .toggle-btn {
                width: 44px;
                height: 44px;
                font-size: 18px;
            }

            .logo {
                font-size: clamp(2.5rem, 10vw, 4rem);
                margin-bottom: 60px;
            }

            .voice-button-container {
                width: 160px;
                height: 160px;
                margin-bottom: 40px;
            }

            .glow-ring {
                width: 160px;
                height: 160px;
            }

            @keyframes expandRing {
                0% {
                    width: 160px;
                    height: 160px;
                    opacity: 1;
                }
                100% {
                    width: 300px;
                    height: 300px;
                    opacity: 0;
                }
            }

            .voice-button {
                width: 140px;
                height: 140px;
            }

            .mic-icon {
                width: 50px;
                height: 50px;
            }

            .audio-visualizer {
                height: 60px;
                margin-bottom: 30px;
            }
        }

        @media (max-width: 480px) {
            .voice-container {
                padding: 16px;
            }

            .logo {
                margin-bottom: 50px;
            }

            .voice-button-container {
                width: 140px;
                height: 140px;
            }

            .voice-button {
                width: 120px;
                height: 120px;
            }

            .mic-icon {
                width: 45px;
                height: 45px;
            }
        }

        /* Landscape mobile */
        @media (max-height: 600px) and (orientation: landscape) {
            .voice-container {
                min-height: auto;
                padding: 20px;
            }

            .logo {
                font-size: 2.5rem;
                margin-bottom: 30px;
            }

            .voice-button-container {
                width: 120px;
                height: 120px;
                margin-bottom: 20px;
            }

            .voice-button {
                width: 100px;
                height: 100px;
            }

            .audio-visualizer {
                height: 40px;
                margin-bottom: 20px;
            }
        }
    </style>
</head>
<body>
    <!-- Gradient background -->
    <div class="gradient-bg"></div>

    <!-- Animated particles -->
    <div class="particles" id="particles"></div>

    <!-- Main voice container -->
    <div class="voice-container">
        <!-- Logo - Only "LyDian" -->
        <div class="logo">LyDian</div>

        <!-- Audio visualizer -->
        <div class="audio-visualizer" id="audioVisualizer"></div>

        <!-- Voice button with glow rings -->
        <div class="voice-button-container">
            <div class="glow-ring"></div>
            <div class="glow-ring"></div>
            <div class="glow-ring"></div>
            <button class="voice-button" id="voiceButton" aria-label="Konuşmaya başla">
                <svg class="mic-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"></path>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"></path>
                    <line x1="12" x2="12" y1="19" y2="22"></line>
                </svg>
            </button>
        </div>

        <!-- Premium Loading Spinner -->
        <div class="spinner" id="spinner">
            <div class="spinner-ring"></div>
            <div class="processing-text">
                <span>Yanıt hazırlanıyor</span><span class="processing-dots"></span>
            </div>
        </div>

        <!-- Hidden transcript -->
        <div class="transcript" id="transcript"></div>
    </div>

    <!-- Permission prompt -->
    <div class="permission-prompt" id="permissionPrompt">
        <h3>Mikrofon İzni</h3>
        <p>Sesli konuşma için mikrofon erişimine izin verin</p>
    </div>

    <!-- Error message -->
    <div class="error-message" id="errorMessage"></div>

    <!-- Chat History Panel -->
    <div class="chat-history" id="chatHistory">
        <div class="chat-history-header">
            <div class="chat-history-title">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
                </svg>
                Sohbet Geçmişi
            </div>
            <button class="chat-clear-btn" id="clearHistoryBtn">Temizle</button>
        </div>
        <div id="chatMessages"></div>
    </div>

    <!-- Voice Settings Panel -->
    <div class="settings-panel" id="settingsPanel">
        <div class="settings-title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M12 1v6m0 6v6m5.2-13.2l-4.2 4.2m0 6l4.2 4.2M23 12h-6m-6 0H1m18.8 5.2l-4.2-4.2m0-6l4.2-4.2"></path>
            </svg>
            <span>Ses Ayarları</span>
        </div>
        <div class="settings-group">
            <div class="settings-label">
                <span>Ses Hızı</span>
                <span class="settings-value" id="rateValue">1.0x</span>
            </div>
            <input type="range" class="settings-slider" id="rateSlider" min="0.5" max="2.0" step="0.1" value="1.0">
        </div>
        <div class="settings-group">
            <div class="settings-label">
                <span>Ses Tonu</span>
                <span class="settings-value" id="pitchValue">1.0</span>
            </div>
            <input type="range" class="settings-slider" id="pitchSlider" min="0.5" max="2.0" step="0.1" value="1.0">
        </div>
        <div class="settings-group">
            <div class="settings-label">
                <span>Ses Seviyesi</span>
                <span class="settings-value" id="volumeValue">100%</span>
            </div>
            <input type="range" class="settings-slider" id="volumeSlider" min="0" max="1" step="0.1" value="1.0">
        </div>
    </div>

    <!-- Toggle Buttons -->
    <div class="toggle-buttons">
        <button class="toggle-btn" id="settingsToggle" aria-label="Ayarlar">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M12 1v6m0 6v6m5.2-13.2l-4.2 4.2m0 6l4.2 4.2M23 12h-6m-6 0H1m18.8 5.2l-4.2-4.2m0-6l4.2-4.2"></path>
            </svg>
        </button>
        <button class="toggle-btn" id="historyToggle" aria-label="Geçmiş">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
        </button>
    </div>

    <script>
        // Voice interface controller with Groq API integration + SIRI QUALITY ENHANCEMENTS
        let recognition;
        let synthesis = window.speechSynthesis;
        let isListening = false;
        let isSpeaking = false;
        let mediaStream;
        let audioContext;
        let analyser;
        let visualizerBars = [];
        let animationFrame;
        let wakeLock = null; // Screen wake lock for background operation

        // CONVERSATION MEMORY - Siri-like context retention
        const MAX_HISTORY = 5; // Keep last 5 messages for context
        let conversationHistory = [];

        // VOICE SETTINGS - Premium customization (optimized for natural Turkish)
        let voiceSettings = {
            rate: 0.95,    // Slightly slower for clearer pronunciation
            pitch: 1.05,   // Slightly higher for warmer tone
            volume: 1.0
        };

        // RETRY LOGIC - Enhanced error recovery
        const MAX_RETRIES = 3;
        const RETRY_DELAY = 1000; // Initial delay in ms

        const elements = {
            voiceButton: document.getElementById('voiceButton'),
            permissionPrompt: document.getElementById('permissionPrompt'),
            errorMessage: document.getElementById('errorMessage'),
            audioVisualizer: document.getElementById('audioVisualizer'),
            spinner: document.getElementById('spinner'),
            transcript: document.getElementById('transcript'),
            particles: document.getElementById('particles'),
            statusText: document.querySelector('.status-text') || document.createElement('div'),
            chatHistory: document.getElementById('chatHistory'),
            chatMessages: document.getElementById('chatMessages'),
            clearHistoryBtn: document.getElementById('clearHistoryBtn'),
            settingsPanel: document.getElementById('settingsPanel'),
            settingsToggle: document.getElementById('settingsToggle'),
            historyToggle: document.getElementById('historyToggle'),
            rateSlider: document.getElementById('rateSlider'),
            pitchSlider: document.getElementById('pitchSlider'),
            volumeSlider: document.getElementById('volumeSlider'),
            rateValue: document.getElementById('rateValue'),
            pitchValue: document.getElementById('pitchValue'),
            volumeValue: document.getElementById('volumeValue')
        };

        // Request screen wake lock to keep device active even when screen is off
        async function requestWakeLock() {
            try {
                if ('wakeLock' in navigator) {
                    wakeLock = await navigator.wakeLock.request('screen');
                    console.log('🔓 Wake Lock active - device will stay awake');

                    wakeLock.addEventListener('release', () => {
                        console.log('🔒 Wake Lock released');
                    });
                } else {
                    console.log('⚠️ Wake Lock API not supported');
                }
            } catch (err) {
                console.error('Wake Lock error:', err);
            }
        }

        // Release wake lock
        function releaseWakeLock() {
            if (wakeLock) {
                wakeLock.release();
                wakeLock = null;
            }
        }

        // Re-request wake lock when page becomes visible
        document.addEventListener('visibilitychange', async () => {
            if (wakeLock !== null && document.visibilityState === 'visible') {
                await requestWakeLock();
            }
        });

        // Initialize
        function init() {
            createParticles();
            createVisualizerBars();
            checkBrowserSupport();
            setupVoiceButton();
            setupSettingsPanel();
            setupChatHistory();
            loadSettings();
        }

        // Setup Settings Panel
        function setupSettingsPanel() {
            // Toggle settings panel
            elements.settingsToggle.addEventListener('click', () => {
                const isOpen = elements.settingsPanel.classList.toggle('show');
                elements.settingsToggle.classList.toggle('active', isOpen);
                if (isOpen) {
                    elements.chatHistory.classList.remove('show');
                    elements.historyToggle.classList.remove('active');
                }
            });

            // Rate slider
            elements.rateSlider.addEventListener('input', (e) => {
                voiceSettings.rate = parseFloat(e.target.value);
                elements.rateValue.textContent = voiceSettings.rate.toFixed(1) + 'x';
                saveSettings();
            });

            // Pitch slider
            elements.pitchSlider.addEventListener('input', (e) => {
                voiceSettings.pitch = parseFloat(e.target.value);
                elements.pitchValue.textContent = voiceSettings.pitch.toFixed(1);
                saveSettings();
            });

            // Volume slider
            elements.volumeSlider.addEventListener('input', (e) => {
                voiceSettings.volume = parseFloat(e.target.value);
                elements.volumeValue.textContent = Math.round(voiceSettings.volume * 100) + '%';
                saveSettings();
            });
        }

        // Setup Chat History
        function setupChatHistory() {
            // Toggle chat history
            elements.historyToggle.addEventListener('click', () => {
                const isOpen = elements.chatHistory.classList.toggle('show');
                elements.historyToggle.classList.toggle('active', isOpen);
                if (isOpen) {
                    elements.settingsPanel.classList.remove('show');
                    elements.settingsToggle.classList.remove('active');
                }
            });

            // Clear history button
            elements.clearHistoryBtn.addEventListener('click', () => {
                if (confirm('Sohbet geçmişini temizlemek istediğinizden emin misiniz?')) {
                    conversationHistory = [];
                    elements.chatMessages.innerHTML = '';
                    localStorage.removeItem('lydian_chat_history');
                    showError('✅ Sohbet geçmişi temizlendi');
                }
            });

            // Load chat history from localStorage
            const savedHistory = localStorage.getItem('lydian_chat_history');
            if (savedHistory) {
                try {
                    conversationHistory = JSON.parse(savedHistory);
                    conversationHistory.forEach(msg => {
                        addChatMessage(msg.role, msg.content, false);
                    });
                } catch (e) {
                    console.error('Failed to load chat history:', e);
                }
            }
        }

        // Add message to chat history UI
        function addChatMessage(role, content, save = true) {
            const messageDiv = document.createElement('div');
            messageDiv.className = `chat-message ${role}`;

            const userDiv = document.createElement('div');
            userDiv.className = 'chat-message-user';

            // Premium SVG icons instead of emoji
            if (role === 'user') {
                userDiv.innerHTML = `
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; vertical-align: middle; margin-right: 4px;">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    <span>Siz</span>
                `;
            } else {
                userDiv.innerHTML = `
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display: inline-block; vertical-align: middle; margin-right: 4px;">
                        <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
                        <path d="M2 17l10 5 10-5"></path>
                        <path d="M2 12l10 5 10-5"></path>
                    </svg>
                    <span>LyDian</span>
                `;
            }

            const textDiv = document.createElement('div');
            textDiv.className = 'chat-message-text';
            textDiv.textContent = content;

            messageDiv.appendChild(userDiv);
            messageDiv.appendChild(textDiv);
            elements.chatMessages.appendChild(messageDiv);

            // Auto-scroll to bottom
            elements.chatMessages.scrollTop = elements.chatMessages.scrollHeight;

            // Save to conversation history
            if (save) {
                conversationHistory.push({ role, content });

                // Keep only last MAX_HISTORY messages
                if (conversationHistory.length > MAX_HISTORY * 2) {
                    conversationHistory = conversationHistory.slice(-MAX_HISTORY * 2);
                }

                // Save to localStorage
                try {
                    localStorage.setItem('lydian_chat_history', JSON.stringify(conversationHistory));
                } catch (e) {
                    console.error('Failed to save chat history:', e);
                }
            }
        }

        // Save settings to localStorage
        function saveSettings() {
            localStorage.setItem('lydian_voice_settings', JSON.stringify(voiceSettings));
        }

        // Load settings from localStorage
        function loadSettings() {
            const saved = localStorage.getItem('lydian_voice_settings');
            if (saved) {
                try {
                    voiceSettings = JSON.parse(saved);
                    elements.rateSlider.value = voiceSettings.rate;
                    elements.pitchSlider.value = voiceSettings.pitch;
                    elements.volumeSlider.value = voiceSettings.volume;
                    elements.rateValue.textContent = voiceSettings.rate.toFixed(1) + 'x';
                    elements.pitchValue.textContent = voiceSettings.pitch.toFixed(1);
                    elements.volumeValue.textContent = Math.round(voiceSettings.volume * 100) + '%';
                } catch (e) {
                    console.error('Failed to load settings:', e);
                }
            }
        }

        // Create animated particles
        function createParticles() {
            const particleCount = window.innerWidth < 768 ? 30 : 50;
            for (let i = 0; i < particleCount; i++) {
                const particle = document.createElement('div');
                particle.className = 'particle';
                particle.style.left = Math.random() * 100 + '%';
                particle.style.top = Math.random() * 100 + '%';
                particle.style.setProperty('--tx', (Math.random() - 0.5) * 200 + 'px');
                particle.style.setProperty('--ty', (Math.random() - 0.5) * 200 + 'px');
                particle.style.animationDelay = Math.random() * 25 + 's';
                elements.particles.appendChild(particle);
            }
        }

        // Create visualizer bars
        function createVisualizerBars() {
            const barCount = window.innerWidth < 768 ? 15 : 25;
            for (let i = 0; i < barCount; i++) {
                const bar = document.createElement('div');
                bar.className = 'visualizer-bar';
                elements.audioVisualizer.appendChild(bar);
                visualizerBars.push(bar);
            }
        }

        // Check browser support
        function checkBrowserSupport() {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (!SpeechRecognition) {
                showError('Tarayıcınız ses tanımayı desteklemiyor. Lütfen Chrome, Edge veya Safari kullanın.');
                return false;
            }
            if (!window.speechSynthesis) {
                showError('Tarayıcınız sesli yanıt özelliğini desteklemiyor.');
                return false;
            }
            return true;
        }

        // Setup voice button
        function setupVoiceButton() {
            elements.voiceButton.addEventListener('click', toggleVoice);

            // Touch feedback for mobile
            elements.voiceButton.addEventListener('touchstart', () => {
                elements.voiceButton.style.transform = 'scale(0.95)';
            });

            elements.voiceButton.addEventListener('touchend', () => {
                elements.voiceButton.style.transform = 'scale(1)';
            });
        }

        // Toggle voice listening
        async function toggleVoice() {
            if (isListening) {
                stopListening();
            } else {
                await startListening();
            }
        }

        // Start listening
        async function startListening() {
            try {
                // Request wake lock to keep device active
                await requestWakeLock();

                // Request microphone permission
                elements.permissionPrompt.classList.add('show');
                mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true });
                elements.permissionPrompt.classList.remove('show');

                // Setup audio context for visualization
                setupAudioContext();

                // Initialize speech recognition
                initializeRecognition();
                recognition.start();

                isListening = true;
                wakeWordMode = true; // BUTON İLE BAŞLATINCA DİREKT AKTİF!
                elements.voiceButton.classList.add('listening');
                document.querySelectorAll('.glow-ring').forEach(ring => ring.classList.add('active'));
                elements.audioVisualizer.classList.add('active');
                elements.transcript.textContent = 'Dinliyorum... 👂';

                console.log('🎤 Listening started - wakeWordMode activated via button');

            } catch (error) {
                console.error('Microphone error:', error);
                elements.permissionPrompt.classList.remove('show');

                if (error.name === 'NotAllowedError') {
                    showError('Mikrofon izni reddedildi. Lütfen tarayıcı ayarlarından izin verin.');
                } else {
                    showError('Mikrofona erişilemiyor. Lütfen bağlantınızı kontrol edin.');
                }
            }
        }

        // Stop listening
        function stopListening() {
            if (recognition) {
                recognition.stop();
            }
            if (mediaStream) {
                mediaStream.getTracks().forEach(track => track.stop());
            }
            if (audioContext) {
                audioContext.close();
            }
            if (animationFrame) {
                cancelAnimationFrame(animationFrame);
            }

            // Release wake lock when not listening
            releaseWakeLock();

            isListening = false;
            wakeWordMode = false; // Reset wake word mode
            elements.voiceButton.classList.remove('listening');
            document.querySelectorAll('.glow-ring').forEach(ring => ring.classList.remove('active'));
            elements.audioVisualizer.classList.remove('active');

            console.log('🔴 Listening stopped');
        }

        // Wake word state
        let wakeWordMode = false;
        const WAKE_WORDS = ['hey lydian', 'hey lidiyan', 'hey lydia', 'lydian', 'lidiyan'];

        // Initialize speech recognition
        function initializeRecognition() {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            recognition = new SpeechRecognition();

            recognition.lang = 'tr-TR';
            recognition.continuous = true; // Continuous listening for wake word
            recognition.interimResults = true;
            recognition.maxAlternatives = 3; // Get more alternatives for better wake word detection

            recognition.onresult = handleRecognitionResult;
            recognition.onerror = handleRecognitionError;
            recognition.onend = handleRecognitionEnd;
        }

        // Check if transcript contains wake word
        function containsWakeWord(text) {
            const lowerText = text.toLowerCase().trim();
            return WAKE_WORDS.some(wakeWord => lowerText.includes(wakeWord));
        }

        // Handle recognition result
        function handleRecognitionResult(event) {
            const result = event.results[event.results.length - 1];
            const transcript = result[0].transcript;
            const lowerTranscript = transcript.toLowerCase().trim();

            console.log('🎤 Transcript:', transcript, '| Final:', result.isFinal);

            // Check all alternatives for wake word
            let wakeWordDetected = false;
            for (let i = 0; i < result.length; i++) {
                if (containsWakeWord(result[i].transcript)) {
                    wakeWordDetected = true;
                    break;
                }
            }

            if (wakeWordDetected && !wakeWordMode) {
                // Wake word detected! Activate listening mode
                console.log('🔔 Wake word detected! Activating...');
                wakeWordMode = true;
                elements.transcript.textContent = 'Dinliyorum... 👂';
                elements.statusText.textContent = 'Dinliyorum';

                // Visual feedback
                elements.voiceButton.style.transform = 'scale(1.1)';
                setTimeout(() => {
                    elements.voiceButton.style.transform = 'scale(1)';
                }, 200);

                // Speak confirmation (will auto re-activate via speakResponse)
                speakResponse('Evet, dinliyorum');
                return;
            }

            if (wakeWordMode && result.isFinal) {
                // In wake word mode, process the command
                console.log('✅ Processing command:', transcript);
                elements.transcript.textContent = transcript;
                // wakeWordMode will be auto re-activated after AI response
                wakeWordMode = false; // Temporarily disable during processing
                processVoiceInput(transcript);
            } else if (!wakeWordMode && result.isFinal) {
                // Not in wake word mode and no wake word detected
                console.log('⏭️  No wake word, continuing to listen...');
                elements.transcript.textContent = 'Bana "Hey Lydian" diyerek sohbete başlayabilirsiniz';
            } else {
                // Interim result
                if (wakeWordMode) {
                    elements.transcript.textContent = transcript + '...';
                }
            }
        }

        // Handle recognition error
        function handleRecognitionError(event) {
            console.error('Recognition error:', event.error);

            const errorMessages = {
                'no-speech': 'Ses algılanamadı. Lütfen tekrar deneyin.',
                'audio-capture': 'Mikrofon erişimi başarısız.',
                'not-allowed': 'Mikrofon izni verilmedi.',
                'network': 'Ağ bağlantı sorunu.'
            };

            showError(errorMessages[event.error] || 'Ses tanıma hatası oluştu.');
            stopListening();
        }

        // Handle recognition end
        function handleRecognitionEnd() {
            console.log('🔴 Recognition ended');
            if (isListening) {
                // Auto-restart if still in listening mode
                setTimeout(() => {
                    if (isListening) {
                        recognition.start();
                    }
                }, 100);
            }
        }

        // Setup audio context for visualization
        function setupAudioContext() {
            audioContext = new (window.AudioContext || window.webkitAudioContext)();
            analyser = audioContext.createAnalyser();
            const source = audioContext.createMediaStreamSource(mediaStream);

            source.connect(analyser);
            analyser.fftSize = 64;

            visualizeAudio();
        }

        // Visualize audio
        function visualizeAudio() {
            const bufferLength = analyser.frequencyBinCount;
            const dataArray = new Uint8Array(bufferLength);

            function draw() {
                if (!isListening && !isSpeaking) {
                    // Reset bars
                    visualizerBars.forEach(bar => {
                        bar.style.height = '10px';
                    });
                    return;
                }

                animationFrame = requestAnimationFrame(draw);
                analyser.getByteFrequencyData(dataArray);

                visualizerBars.forEach((bar, index) => {
                    const value = dataArray[Math.floor(index * bufferLength / visualizerBars.length)];
                    const height = (value / 255) * 60 + 10;
                    bar.style.height = height + 'px';
                });
            }
            draw();
        }

        // Clean mock data and test patterns from API responses
        function cleanMockData(text) {
            if (!text || typeof text !== 'string') return text;

            // Remove common mock data patterns
            const mockPatterns = [
                // Medical advice disclaimers
                /\s*(\*\*)?note:?\s*(this is (not|for|intended))?\s*medical advice[\s\S]*/gi,
                /\s*(\*\*)?disclaimer:?\s*.*medical advice[\s\S]*/gi,
                /\s*(\*\*)?important:?\s*.*medical advice[\s\S]*/gi,

                // Demo/test data markers
                /\s*\[?demo data\]?[\s\S]*/gi,
                /\s*\[?test data\]?[\s\S]*/gi,
                /\s*\[?sample (response|data)\]?[\s\S]*/gi,
                /\s*\[?example (response|data)\]?[\s\S]*/gi,
                /\s*\(this is (a |an )?(test|demo|sample|example)\)[\s\S]*/gi,

                // Mock medical advice patterns
                /\s*please consult (a |your )?((medical|healthcare) )?(professional|doctor|physician)[\s\S]*/gi,
                /\s*seek (professional )?medical (advice|attention)[\s\S]*/gi,
                /\s*i('m| am) not (a )?((medical|healthcare) )?(professional|doctor)[\s\S]*/gi,

                // Generic disclaimers
                /\s*(\*\*)?warning:?\s*.*[\s\S]*/gi,
                /\s*(\*\*)?caution:?\s*.*medical[\s\S]*/gi,
            ];

            let cleanedText = text;

            // Apply all patterns
            mockPatterns.forEach(pattern => {
                cleanedText = cleanedText.replace(pattern, '');
            });

            // Clean up extra whitespace
            cleanedText = cleanedText
                .replace(/\s{3,}/g, ' ')      // Multiple spaces to single
                .replace(/\n{3,}/g, '\n\n')   // Multiple newlines to double
                .trim();                      // Trim edges

            // If cleaning removed everything, return original
            if (cleanedText.length < 10) {
                console.warn('⚠️ Mock data cleaning removed too much text, returning original');
                return text;
            }

            // Log if something was removed
            if (cleanedText.length < text.length) {
                console.log('🧹 Cleaned mock data:', {
                    original: text.length,
                    cleaned: cleanedText.length,
                    removed: text.length - cleanedText.length
                });
            }

            return cleanedText;
        }

        // Process voice input with AI (ENHANCED with conversation memory + retry logic)
        async function processVoiceInput(text) {
            // Show premium processing UI
            elements.spinner.classList.add('show');
            elements.voiceButton.classList.add('processing');
            elements.voiceButton.classList.remove('listening', 'speaking');

            // Add user message to chat history
            addChatMessage('user', text);

            // Build conversation context (last MAX_HISTORY messages)
            const historyContext = conversationHistory
                .slice(-MAX_HISTORY * 2)
                .map(msg => ({
                    role: msg.role === 'user' ? 'user' : 'assistant',
                    content: msg.content
                }));

            let retryCount = 0;
            let lastError = null;

            while (retryCount < MAX_RETRIES) {
                try {
                    console.log(`🤖 Processing voice input (attempt ${retryCount + 1}/${MAX_RETRIES}):`, text);

                    // Call Vercel Serverless Function (API key güvenli!)
                    const response = await fetch('/api/chat', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            message: text,
                            conversationHistory: historyContext
                        })
                    });

                    if (!response.ok) {
                        const errorData = await response.json().catch(() => ({}));
                        console.error('API error:', errorData);
                        throw new Error(`API error: ${response.status}`);
                    }

                    const data = await response.json();
                    console.log('✅ Response from backend API');

                    if (!data || !data.response) {
                        throw new Error('Invalid API response');
                    }

                    // Extract response
                    let aiResponse = data.response || 'Üzgünüm, yanıt alınamadı.';

                    // CLEAN MOCK DATA: Remove test/demo/medical advice patterns
                    aiResponse = cleanMockData(aiResponse);

                    // Hide processing UI
                    elements.spinner.classList.remove('show');
                    elements.voiceButton.classList.remove('processing');

                    // Add AI response to chat history
                    addChatMessage('ai', aiResponse);

                    // Speak the response with custom voice settings
                    await speakResponse(aiResponse);

                    // Success! Break retry loop
                    return;

                } catch (error) {
                    console.error(`❌ AI Error (attempt ${retryCount + 1}):`, error);
                    lastError = error;
                    retryCount++;

                    // Exponential backoff: wait longer between retries
                    if (retryCount < MAX_RETRIES) {
                        const delay = RETRY_DELAY * Math.pow(2, retryCount - 1);
                        console.log(`⏳ Retrying in ${delay}ms...`);
                        await new Promise(resolve => setTimeout(resolve, delay));
                    }
                }
            }

            // All retries failed
            elements.spinner.classList.remove('show');
            elements.voiceButton.classList.remove('processing');
            const errorMsg = 'Bağlantı sorunu yaşıyorum. Lütfen biraz sonra tekrar deneyin.';
            showError(errorMsg);
            await speakResponse(errorMsg);
            addChatMessage('ai', errorMsg);
        }

        // Speak response using Speech Synthesis (ENHANCED with custom voice settings + auto re-activation)
        function speakResponse(text) {
            return new Promise((resolve) => {
                synthesis.cancel();

                const utterance = new SpeechSynthesisUtterance(text);
                utterance.lang = 'tr-TR';

                // Apply custom voice settings - PREMIUM FEATURE
                utterance.rate = voiceSettings.rate;
                utterance.pitch = voiceSettings.pitch;
                utterance.volume = voiceSettings.volume;

                // Find best Turkish voice (premium natural voices first)
                const voices = synthesis.getVoices();

                // Priority order: Premium > Enhanced > Standard
                const turkishVoice =
                    // 1. Try Microsoft Yelda (Premium Turkish)
                    voices.find(voice => voice.name.includes('Yelda')) ||
                    // 2. Try Google Turkish Female
                    voices.find(voice => voice.lang.startsWith('tr') && voice.name.includes('Google') && voice.name.includes('Female')) ||
                    // 3. Try any Turkish female voice
                    voices.find(voice => voice.lang.startsWith('tr') && (voice.name.includes('Female') || voice.name.includes('Kadın') || voice.name.includes('female'))) ||
                    // 4. Fallback to any Turkish voice
                    voices.find(voice => voice.lang.startsWith('tr'));

                if (turkishVoice) {
                    utterance.voice = turkishVoice;
                    console.log('🎙️ Using voice:', turkishVoice.name, '|', turkishVoice.lang);
                } else {
                    console.warn('⚠️ No Turkish voice found, using default');
                }

                utterance.onstart = () => {
                    isSpeaking = true;
                    elements.voiceButton.classList.add('speaking');
                    elements.audioVisualizer.classList.add('active');
                    visualizeAudio();

                    // CRITICAL: Stop speech recognition while speaking to avoid echo/loop
                    if (recognition && isListening) {
                        try {
                            recognition.stop();
                            console.log('🔇 Recognition paused during speech');
                        } catch (e) {
                            console.warn('Recognition stop warning:', e);
                        }
                    }
                };

                utterance.onend = () => {
                    isSpeaking = false;
                    elements.voiceButton.classList.remove('speaking');
                    elements.audioVisualizer.classList.remove('active');

                    // AUTO RE-ACTIVATION: Restart recognition after speaking
                    if (isListening) {
                        setTimeout(() => {
                            wakeWordMode = true;
                            elements.transcript.textContent = 'Dinliyorum...';

                            // Restart speech recognition
                            try {
                                recognition.start();
                                console.log('🔄 Recognition restarted - ready for next command');
                            } catch (e) {
                                console.warn('Recognition restart warning:', e);
                                // Recognition might already be running, that's ok
                            }
                        }, 1000); // 1 second delay to ensure clean transition
                    }

                    resolve();
                };

                utterance.onerror = (error) => {
                    console.error('Speech synthesis error:', error);
                    isSpeaking = false;
                    elements.voiceButton.classList.remove('speaking');
                    elements.audioVisualizer.classList.remove('active');

                    // Even on error, re-activate for next command
                    if (isListening) {
                        wakeWordMode = true;
                    }

                    resolve();
                };

                synthesis.speak(utterance);
            });
        }

        // Show error message
        function showError(message) {
            elements.errorMessage.textContent = message;
            elements.errorMessage.classList.add('show');
            setTimeout(() => {
                elements.errorMessage.classList.remove('show');
            }, 4000);
        }

        // Load voices (Safari requires this)
        if (synthesis.onvoiceschanged !== undefined) {
            synthesis.onvoiceschanged = () => {
                synthesis.getVoices();
            };
        }

        // Initialize on load
        window.addEventListener('load', init);

        // Cleanup on unload
        window.addEventListener('beforeunload', () => {
            if (isListening) {
                stopListening();
            }
            if (synthesis.speaking) {
                synthesis.cancel();
            }
        });
    </script>
</body>
</html>
